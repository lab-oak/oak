# Optional zig PATH prepend
if [ -n "$1" ]; then
    export PATH="$1:$PATH"
    echo "Prepended $1 to PATH"
fi

set -e

BASE_FLAGS="-Dshowdown -Dpic -Doption=ebc=false -Doption=miss=false -Doption=advance=false -Doption=key=true -Dchance -Dcalc --prefix-include-dir ../../../include"

cd cpp/extern/engine

for opt in Debug ReleaseFast; do
  for mode in client chance; do
    OUT="../../../libpkmn/$opt/$mode"

    EXTRA=""
    if [ "$mode" = "client" ]; then
      EXTRA="-Dlog"
    fi

    zig build $BASE_FLAGS $EXTRA -Doptimize=$opt \
      --prefix-lib-dir "$OUT"

    ls "../../libpkmn/$opt/$mode"
  done
done

cd ../../..